<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.unavlab.ucnllauncher" android:versionCode="1" android:versionName="1.0">
	<!-- Оборудование требует USB Host режима -->
	<uses-feature android:name="android.hardware.usb.host" android:required="true" />
	<!-- Базовые разрешения для работы сети -->
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
	<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
	<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
	<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
	<application android:allowBackup="true" android:icon="@mipmap/appicon" android:supportsRtl="true" android:label="UC&amp;NL Launcher" android:theme="@style/MainTheme" android:requestLegacyExternalStorage="true">
		<activity android:name=".MainActivity" android:exported="true">
			<!-- Ваш существующий фильтр для USB -->
			<intent-filter>
				<action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
			</intent-filter>
			<meta-data android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" android:resource="@xml/device_filter" />
		</activity>
	</application>
</manifest>